rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'createdAt', 'author']) &&
             data.text is string && data.text.size() <= 5000 &&
             data.author in ['Him', 'Admin'];
    }

    function isValidMoment(data) {
      return data.keys().hasAll(['image', 'title', 'createdAt']) &&
             data.image is string && data.image.size() <= 900000 &&
             data.title is string && data.title.size() <= 100;
    }

    function isValidArchiveItem(data) {
      return data.keys().hasAll(['image', 'createdAt']) &&
             data.image is string && data.image.size() <= 900000;
    }

    // Allow public read for everything (Celebration site)
    match /conversations/main/messages/{msgId} {
      allow read: if true;
      allow create: if isValidMessage(incoming());
    }

    match /gallery/{momentId} {
      allow read: if true;
      allow create: if isValidMoment(incoming());
    }

    match /archive/{itemId} {
      allow read: if true;
      allow create: if isValidArchiveItem(incoming());
    }

    match /settings/global {
      allow read: if true;
      allow write: if true; // Allows updating hero image and profile pic
    }

    match /presence/{id} {
      allow read: if true;
      allow write: if true;
    }
  }
}
